# Force LF everywhere — consistent across Mac, Linux, Windows
* text=auto eol=lf

# Explicitly text
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.env* text eol=lf
*.sh text eol=lf

# Binary — no conversion
*.png binary
*.jpg binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
